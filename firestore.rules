rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Books collection ─────────────────────────────────────────────────────
    // Students (unauthenticated or authenticated) can read.
    // Only admins (authenticated) can write.
    match /books/{bookId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ─── Book Copies ──────────────────────────────────────────────────────────
    // Students can read (to check availability).
    // Only admins can write (assign copies, mark returned).
    match /bookCopies/{copyId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ─── Orders ───────────────────────────────────────────────────────────────
    // Any user can create an order (students don't need auth to place orders).
    // Students can only read their own order (by studentId field).
    // Admins can read and write all orders.
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null && isAdmin()
                  || (resource != null &&
                      request.auth == null); // Public read for confirmation page
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }

    // ─── Helper function ──────────────────────────────────────────────────────
    // Admins are identified by a custom claim set via Firebase Auth Admin SDK.
    // To set: admin.auth().setCustomUserClaims(uid, { admin: true })
    function isAdmin() {
      return request.auth.token.admin == true;
    }
  }
}
